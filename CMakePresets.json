{
  "version": 4,
  "cmakeMinimumRequired": { "major": 3, "minor": 28, "patch": 0 },
  "vendor": {
    "copyright": "TTS - Tiny Test System: TTS Contributors & Maintainers",
    "license": "BSL-1.0",
    "url": "https://github.com/jfalcou/tts"
  },
  "configurePresets": [
    {
      "name": "base",
      "hidden": true,
      "binaryDir": "${sourceDir}/build/${presetName}",
      "cacheVariables": {
        "TTS_BUILD_TEST": "ON",
        "CMAKE_CXX_SCAN_FOR_MODULES": "OFF",
        "CMAKE_EXPORT_COMPILE_COMMANDS": "ON",
        "CMAKE_CXX_FLAGS": "$env{EXTRA_CXX_FLAGS}",
        "CMAKE_CONFIGURATION_TYPES": "Debug;Release",
        "CMAKE_DEFAULT_BUILD_TYPE": "Debug"
      }
    },
    {
      "name": "unix-base",
      "hidden": true,
      "inherits": ["base"],
      "generator": "Ninja Multi-Config"
    },
    {
      "name": "win-base",
      "hidden": true,
      "inherits": ["base"],
      "generator": "Visual Studio 17 2022",
      "architecture": "x64"
    },
    {
      "name": "libcxx",
      "hidden": true,
      "cacheVariables": {
        "CMAKE_CXX_FLAGS": "-stdlib=libc++ $env{EXTRA_CXX_FLAGS}",
        "CMAKE_EXE_LINKER_FLAGS": "-stdlib=libc++"
      }
    },
    {
      "name": "gcc",
      "inherits": ["unix-base"],
      "cacheVariables": {
        "CMAKE_CXX_COMPILER": "g++"
      }
    },
    {
      "name": "gcc14",
      "inherits": ["unix-base"],
      "cacheVariables": {
        "CMAKE_CXX_COMPILER": "g++-14"
      }
    },
    {
      "name": "clang",
      "inherits": ["unix-base"],
      "cacheVariables": {
        "CMAKE_CXX_COMPILER": "clang++"
      }
    },
    {
      "name": "clang20",
      "inherits": ["unix-base"],
      "cacheVariables": {
        "CMAKE_CXX_COMPILER": "clang++-20"
      }
    },
    {
      "name": "clang-libc++",
      "inherits": ["libcxx","unix-base"],
      "cacheVariables": {
        "CMAKE_CXX_COMPILER": "clang++"
      }
    },
    {
      "name": "clang20-libc++",
      "inherits": ["libcxx","unix-base"],
      "cacheVariables": {
        "CMAKE_CXX_COMPILER": "clang++-20"
      }
    },
    {
      "name": "icpx",
      "inherits": ["unix-base"],
      "cacheVariables": {
        "CMAKE_CXX_COMPILER": "icpx",
        "CMAKE_CXX_FLAGS": "-fp-model=precise $env{EXTRA_CXX_FLAGS}"
      }
    },
    {
      "name": "wasm",
      "inherits": ["unix-base"],
      "cacheVariables": {
        "CMAKE_CXX_COMPILER": "em++",
        "CMAKE_CXX_FLAGS": "-sNO_DISABLE_EXCEPTION_CATCHING $env{EXTRA_CXX_FLAGS}",
        "CMAKE_CROSSCOMPILING_CMD": "${sourceDir}/cmake/run_wasm.sh"
      }
    },
    {
      "name": "android-arm64",
      "inherits": ["unix-base"],
      "cacheVariables": {
        "CMAKE_TOOLCHAIN_FILE": "$env{ANDROID_NDK_ROOT}/build/cmake/android.toolchain.cmake",
        "ANDROID_ABI": "arm64-v8a"
      }
    },
    { "name": "msvc"    , "inherits": ["win-base" ]                         },
    { "name": "clangcl" , "inherits": ["win-base"], "toolset": "ClangCL"    }
  ],
  "buildPresets": [
    { "name": "base-build", "hidden": true, "targets": ["tts-test"] },
    { "name": "gcc"             , "inherits": "base-build", "configurePreset": "gcc"            },
    { "name": "gcc14"           , "inherits": "base-build", "configurePreset": "gcc14"          },
    { "name": "clang"           , "inherits": "base-build", "configurePreset": "clang"          },
    { "name": "clang-libc++"    , "inherits": "base-build", "configurePreset": "clang-libc++"   },
    { "name": "clang20"         , "inherits": "base-build", "configurePreset": "clang20"        },
    { "name": "clang20-libc++"  , "inherits": "base-build", "configurePreset": "clang20-libc++" },
    { "name": "icpx"            , "inherits": "base-build", "configurePreset": "icpx"           },
    { "name": "wasm"            , "inherits": "base-build", "configurePreset": "wasm"           },
    { "name": "android-arm64"   , "inherits": "base-build", "configurePreset": "android-arm64"  },
    { "name": "msvc"            , "inherits": "base-build", "configurePreset": "msvc"           },
    { "name": "clangcl"         , "inherits": "base-build", "configurePreset": "clangcl"        }
  ],
  "testPresets": [
    { "name": "base-test", "hidden": true,  "output": { "outputOnFailure": true }, "configuration": "Debug" },
    { "name": "gcc"             , "inherits": "base-test", "configurePreset": "gcc"             },
    { "name": "gcc14"           , "inherits": "base-test", "configurePreset": "gcc14"           },
    { "name": "clang"           , "inherits": "base-test", "configurePreset": "clang"           },
    { "name": "clang-libc++"    , "inherits": "base-test", "configurePreset": "clang-libc++"    },
    { "name": "clang20"         , "inherits": "base-test", "configurePreset": "clang20"         },
    { "name": "clang20-libc++"  , "inherits": "base-test", "configurePreset": "clang20-libc++"  },
    { "name": "icpx"            , "inherits": "base-test", "configurePreset": "icpx"            },
    { "name": "wasm"            , "inherits": "base-test", "configurePreset": "wasm"            },
    { "name": "android-arm64"   , "inherits": "base-test", "configurePreset": "android-arm64"   },
    { "name": "msvc"            , "inherits": "base-test", "configurePreset": "msvc"            },
    { "name": "clangcl"         , "inherits": "base-test", "configurePreset": "clangcl"         }
  ]
}
